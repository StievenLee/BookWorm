<?xml version="1.0" encoding="utf-8"?>
<!-- Input field ala Figma: kotak putih dengan drop shadow (0 4px, ~25% black).
     Shadow digambar sebagai beberapa lapis gelap makin transparan (efek blur lembut),
     di bawah kotak putih — tidak bergantung pada android:elevation/clipping. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layers (paling luar & samar → paling dalam & pekat) -->
    <item android:top="4dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#10000000" />
            <corners android:radius="@dimen/input_corner_radius" />
        </shape>
    </item>
    <item android:top="4dp" android:left="0dp" android:right="0dp" android:bottom="-1dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000" />
            <corners android:radius="@dimen/input_corner_radius" />
        </shape>
    </item>

    <!-- Kotak putih -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="@dimen/input_corner_radius" />
        </shape>
    </item>
</layer-list>
